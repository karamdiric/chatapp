<div class="max-w-2xl mx-auto">
  <div class="flex justify-between items-center mb-6">
    <h1 class="text-2xl font-bold text-gray-800">Edit Chatroom</h1>
    <%= link_to "Back", @chatroom, class: "text-blue-500 hover:text-blue-600 underline" %>
  </div>

  <div class="bg-white rounded-lg shadow p-6">
    <%= form_with(model: @chatroom) do |f| %>
      <% if @chatroom.errors.any? %>
        <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded mb-4">
          <h2 class="font-bold mb-2">
            <%= pluralize(@chatroom.errors.count, "error") %> prohibited this chatroom from being saved:
          </h2>
          <ul class="list-disc list-inside">
            <% @chatroom.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div class="mb-4">
        <%= f.label :name, class: "block text-gray-700 font-bold mb-2" %>
        <%= f.text_field :name, class: "w-full rounded-lg border-2 bg-[#fbfbfb] border-gray-300 focus:border-blue-500 focus:ring focus:ring-blue-200 p-3 ring ring-gray-400" %>
      </div>

      <div class="mb-6">
        <%= f.label :description, class: "block text-gray-700 font-bold mb-2" %>
        <%= f.text_area :description, rows: 4, class: "w-full rounded-lg border-[2px] bg-[#fbfbfb] border-gray focus:border-blue-500 focus:ring focus:ring-blue-200 p-3 ring ring-gray-400" %>
      </div>

      <div class="flex justify-end">
        <%= f.submit "Update Chatroom", class: "bg-blue-500 hover:bg-blue-600 text-white px-4 py-2 rounded" %>
      </div>
    <% end %>
  </div>
</div>
