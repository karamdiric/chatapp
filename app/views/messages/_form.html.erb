<%= form_with(model: [chatroom, message], class: "flex items-center space-x-4", data: { controller: "message-form", chatroom_channel_target: "form" }) do |f| %>
  <div class="relative flex-1">
    <%= f.text_field :content, 
      class: "block w-full rounded-full border-0 py-4 pl-5 pr-16 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 placeholder:text-gray-400 focus:ring-2 focus:ring-inset focus:ring-blue-600 sm:text-sm sm:leading-6 transition duration-150 ease-in-out",
      placeholder: "Type your message...",
      data: { 
        action: "keydown->message-form#handleKeydown input->message-form#inputChanged",
        message_form_target: "input",
        chatroom_channel_target: "input"
      } %>

    <div class="absolute inset-y-0 right-0 flex py-1.5 pr-1.5" data-message-form-target="preview" data-chatroom_channel-target="preview" class="hidden"></div>
    
    <label for="media-upload" class="absolute inset-y-0 right-0 flex items-center pr-3 cursor-pointer" data-message-form-target="mediaLabel">
      <span class="inline-flex items-center justify-center h-8 w-8 rounded-full bg-gray-100 hover:bg-gray-200 transition-colors">
        <svg class="w-5 h-5 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.172 7l-6.586 6.586a2 2 0 102.828 2.828l6.414-6.586a4 4 0 00-5.656-5.656l-6.415 6.585a6 6 0 108.486 8.486L20.5 13"></path>
        </svg>
        <span class="hidden absolute -top-2 -right-2 bg-blue-600 text-white text-xs w-5 h-5 flex items-center justify-center rounded-full" data-message-form-target="fileCounter" data-chatroom_channel-target="fileCounter"></span>
      </span>
    </label>
    <%= f.file_field :media, 
      class: "hidden", 
      id: "media-upload", 
      data: { 
        action: "change->message-form#handleFileSelect",
        message_form_target: "mediaInput",
        chatroom_channel_target: "mediaInput"
      } %>
  </div>

  <%= f.submit "Send", 
    class: "inline-flex items-center rounded-full bg-blue-600 px-5 py-4 text-sm font-semibold text-white shadow-sm hover:bg-blue-500 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-blue-600 transition duration-150 ease-in-out disabled:opacity-50 disabled:cursor-not-allowed", 
    data: { message_form_target: "submitButton" },
    disabled: true %>
<% end %>